# PDFHorse — environment template. Kopieer naar `.env` (niet committen).

# SMTP — Hostinger mailbox pdfservice@icthorse.nl
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=pdfservice@icthorse.nl
SMTP_PASS=
SMTP_FROM_NAME=PDFHorse (iCt Horse)

# App
APP_PORT=3963
APP_HOST=127.0.0.1
APP_BASE_URL=https://icthorse.nl/PDFHorse
ALLOWED_ORIGIN=https://icthorse.nl

# Limieten
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_SESSION_TOTAL_BYTES=104857600
SESSION_TIMEOUT_S=1800

# OCR
TESSERACT_LANGS=nld+eng
TMP_DIR=/tmp/pdfhorse

# PDFHorse backend env — kopieer naar /opt/pdfhorse/.env (mode 600, root-only).
# Niet committen (zie .gitignore).

# --- Server ---
APP_HOST=127.0.0.1
APP_PORT=3963
ALLOWED_ORIGIN=https://horsecloud55.ddns.net

# --- Limieten ---
MAX_UPLOAD_SIZE_BYTES=52428800     # 50 MB
MAX_SESSION_TOTAL_BYTES=104857600  # 100 MB
MAX_DOCX_BYTES=20971520
MAX_XLSX_BYTES=20971520
MAX_OCR_BYTES=52428800
SESSION_TIMEOUT_S=1800

# --- LibreOffice / OCR ---
SOFFICE_BIN=soffice
SOFFICE_TIMEOUT_S=60
OCRMYPDF_BIN=ocrmypdf
OCR_LANGUAGES=nld+eng
OCR_TIMEOUT_S=180

# --- Mail (v0.9.0-Lamport) ---
# Hostinger SMTP — hergebruikt bestaande info@icthorse.nl mailbox van Facturatie-stijl.
# MAIL_FROM mag een alias binnen icthorse.nl zijn (zoals pdfservice@icthorse.nl) zonder
# dat die mailbox bestaat — Hostinger SMTP zet auto Sender:-header voor SPF.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USE_SSL=False
SMTP_USER=info@icthorse.nl
SMTP_PASSWORD=__VUL_IN_OP_HC55__
SMTP_TIMEOUT_S=30
MAIL_FROM=PDFHorse <pdfservice@icthorse.nl>
MAIL_REPLY_TO=info@icthorse.nl
MAX_MAIL_ATTACHMENT_BYTES=5242880  # 5 MB
MAX_MAIL_SUBJECT_LEN=200
MAX_MAIL_BODY_LEN=100000
MAIL_RATE_PER_HOUR=5/hour
